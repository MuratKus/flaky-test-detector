#!/usr/bin/env bash
# Pre-commit hook: runs ruff linter and formatter check on staged Python files.
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or:      make install-hooks

set -euo pipefail

# Only check staged .py files
STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.py')
if [ -z "$STAGED" ]; then
    exit 0
fi

echo "pre-commit: ruff check on staged Python files..."

# Lint
if ! uv run ruff check $STAGED; then
    echo ""
    echo "Lint errors found. Fix with: uv run ruff check --fix ."
    echo "Then re-stage and commit."
    exit 1
fi

# Format check (don't modify files, just verify)
if ! uv run ruff format --check $STAGED 2>/dev/null; then
    echo ""
    echo "Formatting issues found. Fix with: uv run ruff format ."
    echo "Then re-stage and commit."
    exit 1
fi

echo "pre-commit: all checks passed."
